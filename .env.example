# GDI LATAM - Database Configuration
# Copiar este archivo a .env y completar con valores reales

# PostgreSQL Connection String
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/railway

# Fly.io (via proxy: flyctl proxy 5433:5432 -a <your-postgres-app>)
# DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5433/railway

# Fly.io (conexion interna entre servicios)
# DATABASE_URL=postgresql://postgres:PASSWORD@<your-postgres-app>.internal:5432/railway
